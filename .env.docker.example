# Docker dev environment — copy to .env.docker and fill in values.
# This file is safe to commit (no real secrets).

# Absolute path to your local music library. This path is mounted read-only
# into the liquidsoap container at /music.
MUSIC_DIR=/path/to/your/music

# ─── Icecast2 ──────────────────────────────────────────────────────────────────
ICECAST_SOURCE_PASSWORD=source_password
ICECAST_RELAY_PASSWORD=relay_password
ICECAST_ADMIN_PASSWORD=admin_password
