[Unit]
Description=Rhythm Place Next.js Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ app_root }}
EnvironmentFile={{ app_root }}/.env.production
Environment=NODE_ENV=production
Environment=PORT={{ app_port }}
ExecStart=/home/nginx/.bun/bin/bun --bun next start --port {{ app_port }}
Restart=always
RestartSec=5
TimeoutStartSec=120
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths={{ app_root }}
ReadWritePaths=/home/nginx/.bun

[Install]
WantedBy=multi-user.target
