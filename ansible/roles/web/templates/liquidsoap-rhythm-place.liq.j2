#!/usr/bin/liquidsoap
# rhythm.place — main stream
# Generated by Ansible — do not edit manually.

set("log.file.path", "/var/log/liquidsoap/rhythm-place.log")
set("log.stdout", false)
set("log.level", 3)

# ─── Sources ───────────────────────────────────────────────────────────────────

playlist = playlist(
  mode = "randomize",
  reload = 3600,
  "{{ liquidsoap_playlist_dir }}"
)

# Fallback to silence when playlist is exhausted or unavailable
source = fallback(track_sensitive = false, [playlist, blank()])

# ─── Output ────────────────────────────────────────────────────────────────────

output.icecast(
  %mp3(bitrate = 128, samplerate = 44100, stereo = true),
  host = "127.0.0.1",
  port = {{ icecast_port }},
  password = "{{ icecast_source_password }}",
  mount = "{{ liquidsoap_mount }}",
  name = "{{ app_name }}",
  description = "{{ app_domain }} radio stream",
  url = "https://{{ app_domain }}",
  source
)
