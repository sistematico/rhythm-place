[Unit]
Description=Icecast2 streaming server (rhythm.place)
Documentation=https://icecast.org/
After=network.target
Wants=network.target

[Service]
Type=simple
User=icecast2
Group=icecast
RuntimeDirectory=icecast2
RuntimeDirectoryMode=0755
ExecStart=/usr/bin/icecast2 -c /etc/icecast2/rhythm.xml
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target