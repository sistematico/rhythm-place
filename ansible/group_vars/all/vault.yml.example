---
# ─── Ansible Vault — exemplo de estrutura ──────────────────────────────────────
# Copie este arquivo para ansible/group_vars/all/vault.yml e criptografe com:
#   ansible-vault encrypt ansible/group_vars/all/vault.yml
#
# Para criar direto já criptografado:
#   ansible-vault create ansible/group_vars/all/vault.yml
#
# Account ID: https://dash.cloudflare.com → selecione qualquer domínio → barra lateral direita
# API Token:  https://dash.cloudflare.com/profile/api-tokens → "Create Token"
#   Modelo sugerido: "Edit zone DNS"
#   Permissões:  Zone > DNS > Edit
#   Zone Resources: Include > Specific zone > privatehub.com.br (repetir para pvthub.com)

cloudflare_account_id: "SEU_ACCOUNT_ID_AQUI"
cloudflare_api_token: "SEU_TOKEN_AQUI"

# ─── GitHub Deploy Key ────────────────────────────────────────────────────────
# Gere com: ssh-keygen -t ed25519 -C "deploy@rhythm.place" -f /tmp/rhythm-place-deploy
# Adicione /tmp/rhythm-place-deploy.pub em:
#   https://github.com/sistematico/rhythm-place/settings/keys
# Cole o conteúdo de /tmp/rhythm-place-deploy abaixo (chave privada):
github_deploy_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  COLE_A_CHAVE_PRIVADA_AQUI
  -----END OPENSSH PRIVATE KEY-----

# ─── Icecast2 ──────────────────────────────────────────────────────────────────
icecast_source_password: "SENHA_SOURCE_AQUI"
icecast_relay_password: "SENHA_RELAY_AQUI"
icecast_admin_password: "SENHA_ADMIN_AQUI"